router.put("/marketplace-listings/bulk/status", requireAdmin, async (req, res) => {
  try {
    const ids = Array.isArray(req.body?.ids) ? req.body.ids : [];
    const status = req.body?.status === "approved" ? "approved" : "rejected";
    const update = status === "approved"
      ? { status, isActive: true, isBlocked: false, approvedBy: req.body.approvedBy || "admin", approvedAt: new Date(), rejectedReason: "" }
      : { status, isActive: false, rejectedReason: req.body.rejectedReason || "Rejected by admin" };
    const result = await MarketplaceListing.updateMany({ listingCode: { $in: ids } }, update);
    res.json({ success: true, modified: result.modifiedCount || result.nModified || 0 });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
});

router.put("/marketplace-listings/:id", requireAdmin, async (req, res) => {
  try {
    const allowed = ["rate", "status", "isActive", "isBlocked", "rejectedReason"];
    const update = {};
    allowed.forEach((key) => {
      if (req.body[key] !== undefined) update[key] = req.body[key];
    });
    if (update.rate !== undefined) update.rate = Number(update.rate || 0);
    if (update.status === "approved") {
      update.approvedBy = req.body.approvedBy || "admin";
      update.approvedAt = new Date();
      update.isActive = true;
      update.isBlocked = false;
    }
    const listing = await MarketplaceListing.findOneAndUpdate(listingIdentity(req.params.id), update, { new: true });
    res.json({ success: Boolean(listing), listing });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
});

