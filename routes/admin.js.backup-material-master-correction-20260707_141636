});

router.put("/new-item-requests/:requestCode/approve", requireAdmin, async (req, res) => {
  try {
    const request = await NewItemRequest.findOne({ requestCode: req.params.requestCode });
    if (!request) return res.status(404).json({ success: false, message: "Request not found" });
    const item = await createOrUpdateMasterItem({
      ...req.body,
      itemType: req.body.itemType || request.itemType,
      itemName: req.body.itemName || request.proposedItemName,
      brand: req.body.brand || request.brand,
      specification: req.body.specification || request.specification,
      imageUrl: req.body.imageUrl || request.imageUrl,
    }, req.body?.adminCode || "admin");
    request.status = "approved";
    request.assignedMasterItemCode = item.masterItemCode;
    request.reviewedBy = req.body?.adminCode || "admin";
    request.reviewedAt = new Date();
    request.adminRemarks = req.body?.adminRemarks || "";
    await request.save();
    res.json({ success: true, request, item });
  } catch (error) {
    res.status(error.status || 500).json({ success: false, message: error.message });
  }
});

router.put("/new-item-requests/:requestCode/reject", requireAdmin, async (req, res) => {
  try {
    const request = await NewItemRequest.findOneAndUpdate(
      { requestCode: req.params.requestCode },
      { status: "rejected", adminRemarks: req.body?.adminRemarks || req.body?.reason || "Rejected by admin", reviewedBy: req.body?.adminCode || "admin", reviewedAt: new Date() },
      { new: true }
    );
    res.json({ success: Boolean(request), request });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
});

