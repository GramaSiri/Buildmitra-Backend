const express = require("express");
const jwt = require("jsonwebtoken");
const bcrypt = require("bcryptjs");
const User = require("../models/User");

const router = express.Router();

const JWT_SECRET =
  process.env.JWT_SECRET ||
  "buildmitra-development-secret-change-in-production";

const ROLE_PREFIX = {
  buyer: "BUY",
  contractor: "CON",
  supplier: "SUP",
  vendor: "VEN",
  laboursupply: "LAB",
  machinehire: "MAC",
  realestate: "REA",
  admin: "ADM"
};

function safeUser(user) {
  return {
    id: String(user._id),
    name: user.name || "",
    email: user.email || "",
    phone: user.phone || "",
    role: user.role || "user",
    businessRole: user.businessRole || "buyer",
    userCode: user.userCode || "",
    companyName: user.companyName || user.name || "",
    gstNo: user.gstNo || "",
    officePhone: user.officePhone || "",
    address: user.address || "",
    city: user.city || "",
    state: user.state || "",
    pincode: user.pincode || "",
    isActive: user.isActive !== false,
    isMarketplaceVisible: user.isMarketplaceVisible !== false,
    isVerified: Boolean(user.isVerified),
    blockedReason: user.blockedReason || "",
    assignedProjects: user.assignedProjects || []
  };
}

async function generateUserCode(businessRole) {
  const prefix = ROLE_PREFIX[businessRole] || "USR";

  const existingUsers = await User.find({
    userCode: new RegExp("^" + prefix + "-\\d+$")
  })
    .select("userCode")
    .lean();

  let highestNumber = 0;

  for (const user of existingUsers) {
    const parts = String(user.userCode || "").split("-");
    const number = Number(parts[1] || 0);

    if (Number.isFinite(number) && number > highestNumber) {
      highestNumber = number;
    }
  }

  return prefix + "-" + String(highestNumber + 1).padStart(6, "0");
}

/*
============================================================
REGISTER
============================================================
*/

router.post("/register", async (req, res) => {
  try {
    const name = String(req.body.name || "").trim();
    const email = String(req.body.email || "").trim().toLowerCase();
    const phone = String(req.body.phone || "").replace(/\D/g, "").trim();
    const password = String(req.body.password || "");
    const businessRole = String(
      req.body.businessRole || req.body.userType || req.body.role || "buyer"
    )
      .trim()
      .toLowerCase();

    const allowedRoles = [
      "buyer",
      "contractor",
      "supplier",
      "vendor",
      "laboursupply",
      "machinehire",
      "realestate"
    ];

    if (!name) {
      return res.status(400).json({
        success: false,
        message: "Name is required"
      });
    }

    if (!email) {
      return res.status(400).json({
        success: false,
        message: "Email is required"
      });
    }

    if (!phone || phone.length < 10) {
      return res.status(400).json({
        success: false,
        message: "Valid phone number is required"
      });
    }

    if (!password || password.length < 6) {
      return res.status(400).json({
        success: false,
        message: "Password must contain at least 6 characters"
      });
    }

    if (!allowedRoles.includes(businessRole)) {
      return res.status(400).json({
        success: false,
        message: "Invalid user category"
      });
    }

    const duplicate = await User.findOne({
      $or: [
        { email },
        { phone }
      ]
    });

    if (duplicate) {
      return res.status(409).json({
        success: false,
        message:
          duplicate.email === email
            ? "An account already exists with this email"
            : "An account already exists with this phone number"
      });
    }

    const userCode = await generateUserCode(businessRole);

    const user = new User({
      name,
      email,
      phone,
      password,
      businessRole,
      userCode,
      role: "user",
      companyName: String(req.body.companyName || name).trim(),
      gstNo: String(req.body.gstNo || "").trim(),
      officePhone: String(req.body.officePhone || "").trim(),
      address: String(req.body.address || "").trim(),
      city: String(req.body.city || "").trim(),
      state: String(req.body.state || "").trim(),
      pincode: String(req.body.pincode || "").trim(),
      isVerified: true,
      isActive: true,
      isMarketplaceVisible: true
    });

    await user.save();

    const savedUser = await User.findById(user._id);

    if (!savedUser) {
      throw new Error("User was not saved in database");
    }

    const token = jwt.sign(
      {
        userId: savedUser._id,
        userCode: savedUser.userCode,
        businessRole: savedUser.businessRole
      },
      JWT_SECRET,
      { expiresIn: "7d" }
    );

    return res.status(201).json({
      success: true,
      message: "Registration successful",
      token,
      user: safeUser(savedUser)
    });
  } catch (error) {
    console.error("REGISTER ERROR:", error);

    if (error && error.code === 11000) {
      return res.status(409).json({
        success: false,
        message: "Phone number, email or user code already exists"
      });
    }

    return res.status(500).json({
      success: false,
      message: error.message || "Registration failed"
    });
  }
});

/*
============================================================
LOGIN
============================================================
*/

router.post("/login", async (req, res) => {
  try {
    const loginId = String(
      req.body.phoneOrEmail ||
      req.body.emailOrPhone ||
      req.body.identifier ||
      req.body.email ||
      req.body.phone ||
      ""
    ).trim();

    const password = String(req.body.password || "");

    if (!loginId || !password) {
      return res.status(400).json({
        success: false,
        message: "Phone/email and password are required"
      });
    }

    const normalizedEmail = loginId.toLowerCase();
    const normalizedPhone = loginId.replace(/\D/g, "");

    const user = await User.findOne({
      $or: [
        { email: normalizedEmail },
        { phone: normalizedPhone }
      ]
    }).select("+password");

    if (!user || !user.password) {
      return res.status(401).json({
        success: false,
        message: "Invalid phone/email or password"
      });
    }

    let passwordMatches = false;

    if (typeof user.comparePassword === "function") {
      passwordMatches = await user.comparePassword(password);
    } else {
      passwordMatches = await bcrypt.compare(password, user.password);
    }

    if (!passwordMatches) {
      return res.status(401).json({
        success: false,
        message: "Invalid phone/email or password"
      });
    }

    if (user.isActive === false) {
      return res.status(403).json({
        success: false,
        message: user.blockedReason || "This account is blocked"
      });
    }

    const token = jwt.sign(
      {
        userId: user._id,
        userCode: user.userCode,
        businessRole: user.businessRole
      },
      JWT_SECRET,
      { expiresIn: "7d" }
    );

    return res.json({
      success: true,
      message: "Login successful",
      token,
      user: safeUser(user)
    });
  } catch (error) {
    console.error("LOGIN ERROR:", error);

    return res.status(500).json({
      success: false,
      message: error.message || "Login failed"
    });
  }
});

module.exports = router;
