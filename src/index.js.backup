const express = require("express");
const cors = require("cors");

const app = express();

console.log("🚀 CLEAN INDEX LOADED");

app.use(cors({ origin: "http://localhost:3000" }));
app.use(express.json());

// 🔥 GLOBAL REQUEST TRACE
app.use((req, res, next) => {
  console.log("➡️ REQUEST:", req.method, req.url);
  next();
});

// 🔥 FINAL WORKING API (NO DEPENDENCIES)
app.post("/api/floorplan/generate", (req, res) => {

  console.log("🔥 API HIT CONFIRMED");
  console.log("🔥 BODY:", req.body);

  const plot = {
    width: req.body.plotWidth,
    depth: req.body.plotDepth
  };

  const constraints = {
    bedrooms: req.body.bedrooms,
    vaastu: req.body.vaastu
  };

  const rooms = [
    { id: "hall", name: "Hall", x: 100, y: 100 },
    { id: "kitchen", name: "Kitchen", x: 300, y: 120 },
    { id: "bedroom_1", name: "Bedroom 1", x: 120, y: 300 }
  ];

  const connectivity = {
    hall: ["kitchen", "bedroom_1"]
  };

  res.json({
    success: true,
    message: "FINAL ENGINE WORKING",
    data: {
      plot,
      constraints,
      rooms,
      connectivity
    }
  });
});

const PORT = 5000;

app.listen(PORT, () => {
  console.log("🚀 SERVER RUNNING ON", PORT);
});
